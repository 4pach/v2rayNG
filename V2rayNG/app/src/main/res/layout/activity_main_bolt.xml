<?xml version="1.0" encoding="utf-8"?>
<!-- BoltVPN: Main screen layout — cyberpunk design
     Replaces activity_main.xml (DrawerLayout + ViewPager + FAB)
     New: Connect button + Server selector + Stats + Tab Bar -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bolt_bg"
    android:fitsSystemWindows="true">

    <!-- ====== SCROLLABLE CONTENT ====== -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ====== 1. LOGO ====== -->
            <LinearLayout
                android:id="@+id/layout_logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/iv_logo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@mipmap/ic_launcher"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:id="@+id/tv_logo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/app_name"
                    android:textColor="@color/bolt_text"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- ====== 2. IP STATUS & SECURITY ====== -->
            <LinearLayout
                android:id="@+id/layout_ip_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/iv_lock"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lock_open"
                    android:contentDescription="@string/bolt_traffic_unprotected" />

                <TextView
                    android:id="@+id/tv_ip_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/bolt_traffic_unprotected"
                    android:textColor="@color/bolt_text_dim"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- ====== 3. CONNECT BUTTON ====== -->
            <FrameLayout
                android:id="@+id/btn_connect"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/bolt_connect"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:background="@drawable/bolt_connect_button_bg">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/iv_power"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_power_bolt"
                        android:contentDescription="@string/bolt_connect" />

                    <TextView
                        android:id="@+id/tv_connect_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/bolt_connect"
                        android:textColor="@color/bolt_text_dim"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />
                </LinearLayout>
            </FrameLayout>

            <!-- ====== 4. CONNECTION STATUS ====== -->
            <LinearLayout
                android:id="@+id/layout_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <View
                    android:id="@+id/view_status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bolt_status_dot_gray" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/bolt_status_disconnected"
                    android:textColor="@color/bolt_text_dim"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ====== 5. SERVER SELECTOR ====== -->
            <FrameLayout
                android:id="@+id/layout_server"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:background="@drawable/bolt_card_neon_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Flag placeholder (will be set programmatically) -->
                    <ImageView
                        android:id="@+id/iv_server_flag"
                        android:layout_width="32dp"
                        android:layout_height="24dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/bolt_select_server"
                        tools:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tv_server_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bolt_select_server"
                            android:textColor="@color/bolt_text"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_server_ping"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/bolt_text_dim"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            tools:text="48 ms" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@string/bolt_select_server" />
                </LinearLayout>
            </FrameLayout>

            <!-- ====== 6. STATS — 3 cards in a row ====== -->
            <LinearLayout
                android:id="@+id/layout_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:baselineAligned="false">

                <!-- Download speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bolt_card_bg"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bolt_speed_down"
                        android:textColor="@color/bolt_text_dim"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_speed_down"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/bolt_neon"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Мб/с"
                        android:textColor="@color/bolt_text_dim"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Upload speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bolt_card_bg"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bolt_speed_up"
                        android:textColor="@color/bolt_text_dim"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_speed_up"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0"
                        android:textColor="@color/bolt_neon"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Мб/с"
                        android:textColor="@color/bolt_text_dim"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Session timer -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bolt_card_bg"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bolt_session_time"
                        android:textColor="@color/bolt_text_dim"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="00:00"
                        android:textColor="@color/bolt_neon"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" "
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ====== 7. TRAFFIC TOTALS ====== -->
            <TextView
                android:id="@+id/tv_traffic_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="@color/bolt_text_dim"
                android:textSize="12sp"
                android:fontFamily="monospace"
                tools:text="↓ 145 MB / ↑ 23 MB" />

            <!-- ====== 8. ENCRYPTION INDICATOR ====== -->
            <LinearLayout
                android:id="@+id/layout_encryption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_lock_closed"
                    android:contentDescription="@string/bolt_traffic_encrypted" />

                <TextView
                    android:id="@+id/tv_encryption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/bolt_encryption_label"
                    android:textColor="@color/bolt_green"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- ====== 9. PROGRESS BAR (connection) ====== -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="invisible"
                app:indicatorColor="@color/bolt_neon"
                app:trackColor="@color/bolt_card" />

            <!-- ====== 10. TEST STATE (legacy, hidden — needed for binding compatibility) ====== -->
            <LinearLayout
                android:id="@+id/layout_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_test_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_test_pending" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ====== BOTTOM NAVIGATION ====== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bolt_bottom_nav_bg"
        app:itemIconTint="@color/bolt_text_dim"
        app:itemTextColor="@color/bolt_text_dim"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
