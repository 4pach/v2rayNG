<?xml version="1.0" encoding="utf-8"?>
<!-- BoltVPN: Night mode uses the same cyberpunk palette as day mode.
     Our app is always dark — no day/night distinction needed.
     All colors reference the base values/colors.xml via @color/bolt_* -->
<resources>
    <color name="color_fab_active">@color/bolt_neon</color>
    <color name="color_fab_inactive">@color/bolt_text_dim</color>
    <color name="divider_color_light">@color/bolt_border</color>

    <!-- Material theme — same as day mode (always dark cyberpunk) -->
    <color name="md_theme_primary">@color/bolt_neon</color>
    <color name="md_theme_onPrimary">@color/bolt_bg</color>
    <color name="md_theme_primaryContainer">@color/bolt_card</color>
    <color name="md_theme_onPrimaryContainer">@color/bolt_text</color>

    <color name="md_theme_secondary">@color/bolt_neon_dim</color>
    <color name="md_theme_onSecondary">@color/bolt_bg</color>
    <color name="md_theme_secondaryContainer">@color/bolt_card</color>
    <color name="md_theme_onSecondaryContainer">@color/bolt_text</color>

    <color name="md_theme_tertiary">@color/bolt_green</color>
    <color name="md_theme_onTertiary">@color/bolt_bg</color>
    <color name="md_theme_tertiaryContainer">#1A00ff88</color>
    <color name="md_theme_onTertiaryContainer">@color/bolt_green</color>

    <color name="md_theme_error">@color/bolt_red</color>
    <color name="md_theme_errorContainer">#1Aff4466</color>
    <color name="md_theme_onError">@color/bolt_bg</color>
    <color name="md_theme_onErrorContainer">@color/bolt_red</color>

    <color name="md_theme_background">@color/bolt_bg</color>
    <color name="md_theme_onBackground">@color/bolt_text</color>

    <color name="md_theme_surface">@color/bolt_bg</color>
    <color name="md_theme_onSurface">@color/bolt_text</color>
    <color name="md_theme_surfaceVariant">@color/bolt_card</color>
    <color name="md_theme_onSurfaceVariant">@color/bolt_text_dim</color>
    <color name="md_theme_inverseSurface">@color/bolt_text</color>
    <color name="md_theme_inverseOnSurface">@color/bolt_bg</color>

    <color name="md_theme_outline">@color/bolt_border</color>
    <color name="md_theme_outlineVariant">@color/bolt_border</color>

    <color name="md_theme_inversePrimary">@color/bolt_neon_dim</color>
    <color name="md_theme_shadow">#000000</color>
    <color name="md_theme_surfaceTint">@color/bolt_neon</color>
    <color name="md_theme_scrim">#000000</color>
</resources>
